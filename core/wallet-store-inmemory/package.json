{
    "name": "@canton-network/core-wallet-store-inmemory",
    "version": "1.8.0",
    "type": "module",
    "description": "In-memory implementation of the Store API",
    "author": "Marc Juchli <marc.juchli@digitalasset.com>",
    "license": "Apache-2.0",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "scripts": {
        "build": "tsup --onSuccess \"tsc\"",
        "dev": "tsup --watch --onSuccess \"tsc\"",
        "flatpack": "yarn pack --out \"$FLATPACK_OUTDIR\"",
        "clean": "tsc -b --clean; rm -rf dist",
        "test": "vitest run --project node",
        "test:coverage": "vitest run --project node --coverage"
    },
    "dependencies": {
        "@canton-network/core-wallet-auth": "workspace:^",
        "@canton-network/core-wallet-store": "workspace:^",
        "pino": "^10.3.1",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@vitest/browser-playwright": "^4.1.8",
        "@vitest/coverage-v8": "^4.1.8",
        "playwright": "^1.60.0",
        "tsup": "^8.5.1",
        "typescript": "^5.9.3",
        "vitest": "^4.1.8"
    },
    "files": [
        "dist/**"
    ],
    "publishConfig": {
        "access": "public"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/canton-network/wallet.git",
        "directory": "core/wallet-store-inmemory"
    }
}
