{
    "name": "@canton-network/core-rpc-transport",
    "version": "1.7.0",
    "type": "module",
    "description": "RPC transport implementations",
    "license": "Apache-2.0",
    "author": "Digital Asset (Switzerland) GmbH and/or its affiliates",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs",
            "default": "./dist/index.js"
        }
    },
    "scripts": {
        "build": "tsup --onSuccess \"tsc\"",
        "dev": "tsup --watch --onSuccess \"tsc\"",
        "flatpack": "yarn pack --out \"$FLATPACK_OUTDIR\"",
        "clean": "tsc -b --clean; rm -rf dist",
        "test": "vitest run --project node --project browser",
        "test:coverage": "vitest run --project node --project browser --coverage"
    },
    "dependencies": {
        "@canton-network/core-types": "workspace:^",
        "uuid": "^14.0.0"
    },
    "devDependencies": {
        "@vitest/browser-playwright": "^4.1.8",
        "@vitest/coverage-v8": "^4.1.8",
        "playwright": "^1.60.0",
        "tsup": "^8.5.1",
        "typescript": "^5.9.3",
        "vitest": "^4.1.8"
    },
    "files": [
        "dist/**"
    ],
    "publishConfig": {
        "access": "public"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/canton-network/wallet.git",
        "directory": "core/rpc-transport"
    },
    "homepage": "https://github.com/canton-network/wallet/tree/main/core/rpc-transport#readme",
    "bugs": {
        "url": "https://github.com/canton-network/wallet/issues"
    }
}
