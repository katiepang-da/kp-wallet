{
    "name": "@canton-network/core-wallet-user-rpc-client",
    "version": "1.7.0",
    "type": "module",
    "description": "TypeScript client generated by OpenRPC",
    "license": "Apache-2.0",
    "main": "dist/index.cjs",
    "module": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs",
            "default": "./dist/index.js"
        }
    },
    "scripts": {
        "build": "tsup --onSuccess \"tsc --emitDeclarationOnly --declarationMap && yarn run docs\"",
        "docs": "typedoc --tsconfig tsconfig.docs.json",
        "dev": "tsup --watch --onSuccess \"tsc --emitDeclarationOnly --declarationMap && yarn run docs\"",
        "flatpack": "yarn pack --out \"$FLATPACK_OUTDIR\"",
        "clean": "tsc -b --clean; rm -rf dist"
    },
    "files": [
        "dist/**"
    ],
    "publishConfig": {
        "access": "public"
    },
    "dependencies": {
        "@canton-network/core-rpc-transport": "workspace:^",
        "@canton-network/core-types": "workspace:^",
        "lodash": "^4.18.1"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/isomorphic-fetch": "^0.0.39",
        "@types/json-schema": "7.0.15",
        "@types/lodash": "^4.17.24",
        "@types/ws": "^8.18.1",
        "@typescript-eslint/eslint-plugin": "^8.61.0",
        "@typescript-eslint/parser": "^8.61.0",
        "eslint": "^10.5.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.6",
        "globals": "^17.6.0",
        "prettier": "^3.8.4",
        "tsup": "^8.5.1",
        "typedoc": "^0.28.19",
        "typescript": "^5.9.3"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/canton-network/wallet.git",
        "directory": "core/wallet-user-rpc-client"
    },
    "homepage": "https://github.com/canton-network/wallet/tree/main/core/wallet-user-rpc-client#readme",
    "bugs": {
        "url": "https://github.com/canton-network/wallet/issues"
    }
}
